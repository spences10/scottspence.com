{
	"name": "scottspence.com",
	"private": true,
	"packageManager": "pnpm@11.9.0",
	"engines": {
		"node": ">=24.0.0",
		"pnpm": ">=11.0.0"
	},
	"author": {
		"name": "Scott Spence",
		"email": "yo@scottspence.dev",
		"url": "https://scottspence.com"
	},
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"start": "node ./build/index.js",
		"dev": "vp dev",
		"build": "vp build",
		"preview": "vp preview",
		"check": "svelte-kit sync && vp check && svelte-check --tsconfig ./tsconfig.json && prettier --check .",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "vp check --fix && prettier --write .",
		"lint": "vp check",
		"test:unit": "vitest",
		"test:server": "vitest --project=server",
		"test:client": "vitest --project=client",
		"test:ssr": "vitest --project=ssr",
		"test": "pnpm test:unit -- --run && pnpm test:e2e",
		"test:e2e": "playwright test",
		"test:ui": "vitest --ui",
		"test:ci": "vitest run",
		"cspell": "cspell '**/*.md' --config cspell.json --wordsOnly",
		"coverage": "vitest run --coverage"
	},
	"devDependencies": {
		"@fontsource-variable/manrope": "^5.2.8",
		"@fontsource-variable/victor-mono": "^5.2.8",
		"@fontsource/comic-neue": "^5.2.7",
		"@playwright/test": "^1.61.1",
		"@sveltejs/adapter-node": "^5.5.7",
		"@sveltejs/kit": "^2.68.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/typography": "0.5.20",
		"@tailwindcss/vite": "^4.3.1",
		"@types/better-sqlite3": "^7.6.13",
		"@types/d3-scale": "^4.0.9",
		"@types/node": "^26.0.1",
		"@upstash/ratelimit": "^2.0.8",
		"@upstash/redis": "^1.38.0",
		"@vitest/browser": "4.1.9",
		"@vitest/browser-playwright": "4.1.9",
		"cspell": "^10.0.1",
		"d3-scale": "^4.0.2",
		"daisyui": "5.6.3",
		"date-fns": "4.4.0",
		"fathom-client": "3.7.2",
		"layerchart": "2.0.0-next.65",
		"marked": "18.0.5",
		"mdsvex": "^0.12.7",
		"mermaid": "^11.16.0",
		"playwright": "^1.61.1",
		"prettier": "^3.9.0",
		"prettier-plugin-svelte": "^4.1.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"rehype-autolink-headings": "7.1.0",
		"rehype-external-links": "^3.0.0",
		"rehype-slug": "6.0.0",
		"remark-preview": "1.0.3",
		"resend": "^6.16.0",
		"slugify": "1.6.9",
		"svead": "^0.0.16",
		"svelte": "^5.56.4",
		"svelte-check": "^4.7.1",
		"svelte-turnstile": "^0.11.0",
		"sveltekit-embed": "^0.0.22",
		"tailwindcss": "^4.3.1",
		"typescript": "^6.0.3",
		"unist-util-visit": "5.1.0",
		"valibot": "^1.4.1",
		"vite-plus": "0.2.1",
		"vitest": "4.1.9",
		"vitest-browser-svelte": "^2.1.1"
	},
	"dependencies": {
		"@octokit/rest": "^22.0.1",
		"@types/d3-shape": "^3.1.8",
		"better-sqlite3": "^12.11.1",
		"d3-shape": "^3.2.0",
		"sqlite-vec": "0.1.9"
	}
}
